package build

import mill._
import mill.scalalib._
import mill.scalalib.scalafmt._

/** Mill build for ddd-sample-scala.
  *
  * Single module `ddd` mirrors the upstream `citerus/dddsample-core`
  * dependency set, plus our test stack (ScalaTest + Mockito + ScalaCheck).
  *
  * Common commands (run from the repo root):
  *
  *   mill ddd.compile               — compile main sources
  *   mill ddd.test                  — run all tests
  *   mill 'ddd.test.testOnly *CargoTest'
  *   mill ddd.run                   — boot Spring Boot on :8080
  *   mill __.reformat               — scalafmt all modules
  *   mill __.checkFormat            — CI-style format check
  *
  * Mill 1.x renamed the dependency DSL from `ivy"..."` to `mvn"..."` and
  * the corresponding `ivyDeps` task to `mvnDeps`. Everything else maps
  * one-to-one onto the previous sbt build.
  */
object ddd extends ScalaModule with ScalafmtModule {

  // Keep the historical Maven/sbt layout (`src/main/scala`, `src/test/scala`,
  // `src/main/resources`) rather than Mill's `ddd/src` default — minimises
  // diff churn and keeps the layout familiar to anyone arriving from the
  // upstream Java project or the sbt-era branches.
  override def sources   = Task.Sources(mill.api.BuildCtx.workspaceRoot / "src" / "main" / "scala")
  override def resources = Task.Sources(mill.api.BuildCtx.workspaceRoot / "src" / "main" / "resources")

  def scalaVersion = "3.3.4"

  def javacOptions = Seq("--release", "21")

  def scalacOptions = Seq(
    "-deprecation",
    "-feature",
    "-unchecked",
    "-encoding", "UTF-8",
    "-explain",
    "-source:3.3",
    "-Wunused:imports"
    // -Wvalue-discard / -Xfatal-warnings stay off; see CLAUDE.md follow-up
  )

  override def mainClass = Some("se.citerus.dddsample.Application")

  private val SpringBootVersion = "3.3.10"

  def mvnDeps = Seq(
    // Spring Boot starters bring in Jakarta EE 10, Hibernate 6, Jackson,
    // embedded Tomcat, etc. as transitive deps — no need to pin them here.
    mvn"org.springframework.boot:spring-boot-starter-web:$SpringBootVersion",
    mvn"org.springframework.boot:spring-boot-starter-data-jpa:$SpringBootVersion",
    mvn"org.springframework.boot:spring-boot-starter-activemq:$SpringBootVersion",
    mvn"org.springframework.boot:spring-boot-starter-actuator:$SpringBootVersion",
    mvn"org.springframework.boot:spring-boot-starter-validation:$SpringBootVersion",
    mvn"org.springframework.boot:spring-boot-starter-thymeleaf:$SpringBootVersion",
    // ActiveMQ Classic 6.x (Jakarta) for in-process broker + Spring wiring.
    mvn"org.apache.activemq:activemq-broker:6.1.8",
    mvn"org.apache.activemq:activemq-spring:6.1.8",
    // Apache Commons utilities — null checks, string utils, builders.
    mvn"org.apache.commons:commons-lang3:3.20.0",
    mvn"commons-io:commons-io:2.18.0",
    // HSQLDB for the dev profile + integration tests (matches upstream Java).
    mvn"org.hsqldb:hsqldb:2.7.4",
    // jackson-module-scala lets Jackson serialize/deserialize Scala `Option`
    // and case classes natively. Used by the JMS payload serializer so we
    // can drop `scala` from the broker's setTrustedPackages list (any future
    // attacker reaching the queue can't pivot through Java deserialization
    // of `scala.Some` / `scala.None` etc.). Version-aligned with the
    // Jackson 2.18.x that Spring Boot 3.3.10 brings in transitively.
    mvn"com.fasterxml.jackson.module::jackson-module-scala:2.18.2",
    // Magnum + H2 — PoC for the Magnum-based phase 9b persistence layer.
    // Lives alongside the in-memory repos; not yet wired into Spring beans
    // (the in-memory `@Repository`-annotated impls are still authoritative).
    // Exercised end-to-end via MagnumCargoRepositoryTest against H2 in-memory.
    mvn"com.augustnagro::magnum:1.3.1",
    mvn"com.h2database:h2:2.3.232"
  )

  object test extends ScalaTests with TestModule.ScalaTest with ScalafmtModule {
    // Tests live in `src/test/scala` per the Maven/sbt layout, not Mill's
    // default of `ddd/test/src`.
    override def sources = Task.Sources(mill.api.BuildCtx.workspaceRoot / "src" / "test" / "scala")
    override def resources =
      Task.Sources(mill.api.BuildCtx.workspaceRoot / "src" / "test" / "resources")

    def mvnDeps = Seq(
      mvn"org.springframework.boot:spring-boot-starter-test:$SpringBootVersion"
        .exclude("org.junit.vintage" -> "junit-vintage-engine"),
      mvn"org.scalatest::scalatest:3.2.20",
      mvn"org.scalacheck::scalacheck:1.19.0",
      mvn"org.scalatestplus::scalacheck-1-18:3.2.19.0",
      mvn"org.scalatestplus::mockito-5-12:3.2.19.0"
    )
  }
}
